        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <img src="https://static.scientificamerican.com/sciam/cache/file/1FD432BD-1DC9-4EE3-B2F3494EBAE7DCAE_source.jpg" class="card-img-top">
                <div class="card-body text-center">
                    <h5>Buddy</h5>
                    <p>Loyal and energetic.</p>
                        <a href="/Home/Application?name=Buddy&type=Dog" class="btn btn-primary w-100">
                            Adopt
                        </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <img src="https://www.tierschutzbund.de/fileadmin/_processed_/8/1/csm_Listenhund_Michaela__Weidefeld_liegend_im_Gras_c-DTSchB_a9a551d4d8.jpg" class="card-img-top">
                <div class="card-body text-center">
                    <h5>Max</h5>
                    <p>Friendly and protective.</p>
                        <a href="/Home/Application?name=Max&type=Dog" class="btn btn-primary w-100">
                            Adopt
                        </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm">
                <img src="https://ca-times.brightspotcdn.com/dims4/default/fef5695/2147483647/strip/true/crop/1245x799+0+0/resize/1200x770!/quality/75/?url=https%3A%2F%2Fcalifornia-times-brightspot.s3.amazonaws.com%2F03%2Fd8%2Fad409af4471c842f69a53d2e8371%2Fapartment-dogs-corgi-hero.jpg" class="card-img-top">
                <div class="card-body text-center">
                    <h5>Alphy</h5>
                    <p>Playful and Lovely.</p>
                        <a href="/Home/Application?name=Alphy&type=Dog" class="btn btn-primary w-100">
                            Adopt
                        </a>
                </div>
            </div>
        </div>

    </div>

</div>